# Copy this file to .env.local and provide development values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
# Optional community-operation suggestions. Disabled unless explicitly enabled.
ENABLE_OPERATION_AI=false
# Optional. Falls back to the project's default text model.
OPENAI_OPERATION_MODEL=gpt-5.4-mini
# Optional canonical deployment URL for Supabase dashboard configuration.
# Example: https://modiza-mvp-web.vercel.app
NEXT_PUBLIC_SITE_URL=
